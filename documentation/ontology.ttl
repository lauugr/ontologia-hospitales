@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hosp: <https://w3id.org/def/salud/hospital#> .
@prefix mod: <https://w3id.org/mod#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcterms:created a owl:AnnotationProperty .

dcterms:creator a owl:AnnotationProperty .

dcterms:description a owl:AnnotationProperty .

dcterms:license a owl:AnnotationProperty .

dcterms:title a owl:AnnotationProperty .

vann:preferredNamespacePrefix a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

owl:versionIRI a owl:AnnotationProperty .

owl:versionInfo a owl:AnnotationProperty .

schema:address a owl:ObjectProperty ;
    rdfs:label "address" ;
    rdfs:domain schema:Hospital ;
    rdfs:range schema:PostalAddress .

schema:addressCountry a owl:ObjectProperty ;
    rdfs:label "address country" ;
    rdfs:domain schema:PostalAddress ;
    rdfs:range schema:Country .

schema:addressLocality a owl:ObjectProperty ;
    rdfs:label "address locality" ;
    rdfs:domain schema:PostalAddress ;
    rdfs:range hosp:Municipality .

schema:addressRegion a owl:ObjectProperty ;
    rdfs:label "address region" ;
    rdfs:domain schema:PostalAddress ;
    rdfs:range hosp:AutonomousCommunity .

schema:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:domain schema:Hospital ;
    rdfs:range xsd:string .

schema:postalCode a owl:DatatypeProperty ;
    rdfs:label "postal code" ;
    rdfs:domain schema:PostalAddress ;
    rdfs:range xsd:string .

schema:streetAddress a owl:DatatypeProperty ;
    rdfs:label "street address" ;
    rdfs:domain schema:PostalAddress ;
    rdfs:range xsd:string .

schema:telephone a owl:DatatypeProperty ;
    rdfs:label "telephone" ;
    rdfs:domain schema:Hospital ;
    rdfs:range xsd:string .

hosp:addressProvince a owl:ObjectProperty ;
    rdfs:label "address province" ;
    rdfs:domain schema:PostalAddress ;
    rdfs:range hosp:Province .

hosp:ccnCode a owl:DatatypeProperty ;
    rdfs:label "ccn code" ;
    rdfs:domain schema:Hospital ;
    rdfs:range xsd:string .

hosp:cnhCode a owl:DatatypeProperty ;
    rdfs:label "cnh code" ;
    rdfs:domain schema:Hospital ;
    rdfs:range xsd:string .

hosp:containedInCountry a owl:ObjectProperty ;
    rdfs:label "contained in country" ;
    rdfs:domain hosp:AutonomousCommunity ;
    rdfs:range schema:Country .

hosp:containedInProvince a owl:ObjectProperty ;
    rdfs:label "contained in province" ;
    rdfs:domain hosp:Municipality ;
    rdfs:range hosp:Province .

hosp:containedInRegion a owl:ObjectProperty ;
    rdfs:label "contained in region" ;
    rdfs:domain hosp:Province ;
    rdfs:range hosp:AutonomousCommunity .

hosp:hasConcertAgreement a owl:ObjectProperty ;
    rdfs:label "has concert agreement" ;
    rdfs:domain schema:Hospital ;
    rdfs:range hosp:ConcertAgreement .

hosp:hasFunctionalDependency a owl:ObjectProperty ;
    rdfs:label "has functional dependency" ;
    rdfs:domain schema:Hospital ;
    rdfs:range hosp:FunctionalDependency .

hosp:hasHospitalType a owl:ObjectProperty ;
    rdfs:label "has hospital type" ;
    rdfs:domain schema:Hospital ;
    rdfs:range hosp:HospitalType .

hosp:numberOfBeds a owl:DatatypeProperty ;
    rdfs:label "number of beds" ;
    rdfs:domain schema:Hospital ;
    rdfs:range xsd:int .

hosp:teachingAccreditation a owl:DatatypeProperty ;
    rdfs:label "teaching accreditation" ;
    rdfs:domain schema:Hospital ;
    rdfs:range xsd:boolean .

schema:CivicStructure a owl:Class ;
    rdfs:label "Civic Structure" ;
    rdfs:subClassOf schema:Place .

schema:MedicalOrganization a owl:Class ;
    rdfs:label "Medical Organization" ;
    rdfs:subClassOf schema:Organization .

schema:Organization a owl:Class ;
    rdfs:label "Organization" .

schema:Place a owl:Class ;
    rdfs:label "Place" .

hosp: a owl:Ontology ;
    dcterms:created "2026-03-10"^^xsd:date ;
    dcterms:creator "Laura Gilgado Romero" ;
    dcterms:description "Ontología que describe los elementos asociados a los hospitales, entendidos como infraestructura sanitaria."@es ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "Ontología para la representación de hospitales"@es ;
    vann:preferredNamespacePrefix "hosp" ;
    vann:preferredNamespaceUri hosp: ;
    owl:versionIRI <https://w3id.org/def/salud/hospital/0.2> ;
    owl:versionInfo "0.2" ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

hosp:ConcertAgreement a owl:Class ;
    rdfs:label "Concert Agreement" .

hosp:FunctionalDependency a owl:Class ;
    rdfs:label "Functional Dependency" .

hosp:HospitalType a owl:Class ;
    rdfs:label "Hospital Type" .

schema:Country a owl:Class ;
    rdfs:label "Country" .

hosp:Municipality a owl:Class ;
    rdfs:label "Municipality" ;
    rdfs:subClassOf schema:AdministrativeArea .

schema:AdministrativeArea a owl:Class ;
    rdfs:label "Administrative Area" .

hosp:AutonomousCommunity a owl:Class ;
    rdfs:label "Autonomous Community" ;
    rdfs:subClassOf schema:AdministrativeArea .

hosp:Province a owl:Class ;
    rdfs:label "Province" ;
    rdfs:subClassOf schema:AdministrativeArea .

schema:PostalAddress a owl:Class ;
    rdfs:label "Postal Address" .

schema:Hospital a owl:Class ;
    rdfs:label "Hospital" ;
    rdfs:subClassOf schema:CivicStructure,
        schema:MedicalOrganization .

