@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .

@prefix hosp: <https://w3id.org/def/salud/hospital#> .
@prefix hospkos: <https://w3id.org/def/salud/hospital/kos/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

hospkos:HospitalType a skos:ConceptScheme ; 
    dct:issued "2026-03-10"^^xsd:date ;
    dct:modified "2026-03-10"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "Esquema de conceptos para los tipos de hospitales."@es ;
    rdfs:label "Tipos de hospitales"@es ;
    dct:title "Esquema de conceptos agrupando tipos de hospitales"@es ;
    skos:note "Valores extraídos del conjunto de datos de hospitales."@es .

#################################################################
#
#    Concepts
#
#################################################################

<https://w3id.org/salud/recurso/hospital/hospitalType/Hospitales%20generales> a hosp:HospitalType , skos:Concept ;
  skos:inScheme hospkos:HospitalType ;
  skos:prefLabel "Hospitales generales"@es .

<https://w3id.org/salud/recurso/hospital/hospitalType/Hospitales%20especializados> a hosp:HospitalType , skos:Concept ;
  skos:inScheme hospkos:HospitalType ;
  skos:prefLabel "Hospitales especializados"@es .

<https://w3id.org/salud/recurso/hospital/hospitalType/Hospitales%20de%20salud%20mental%20y%20tratamiento%20de%20toxicoman%C3%ADas> a hosp:HospitalType , skos:Concept ;
  skos:inScheme hospkos:HospitalType ;
  skos:prefLabel "Hospitales de salud mental y tratamiento de toxicomanías"@es .

<https://w3id.org/salud/recurso/hospital/hospitalType/Otros%20centros%20con%20internamiento> a hosp:HospitalType , skos:Concept ;
  skos:inScheme hospkos:HospitalType ;
  skos:prefLabel "Otros centros con internamiento"@es .

<https://w3id.org/salud/recurso/hospital/hospitalType/Hospitales%20de%20media%20y%20larga%20estancia> a hosp:HospitalType , skos:Concept ;
  skos:inScheme hospkos:HospitalType ;
  skos:prefLabel "Hospitales de media y larga estancia"@es .