# =========================================
# VALIDACIÓN DEL GRAFO RDF
# =========================================

PREFIX hosp: <https://w3id.org/def/salud/hospital#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>

# -----------------------------------------
# 1. Número total de hospitales
# -----------------------------------------
SELECT (COUNT(?h) AS ?numHospitales)
WHERE {
  ?h rdf:type schema:Hospital .
}

# -----------------------------------------
# 2. Hospitales sin nombre
# -----------------------------------------
SELECT ?h
WHERE {
  ?h rdf:type schema:Hospital .
  FILTER NOT EXISTS { ?h schema:name ?name }
}

# -----------------------------------------
# 3. Hospitales sin dirección
# -----------------------------------------
SELECT ?h
WHERE {
  ?h rdf:type schema:Hospital .
  FILTER NOT EXISTS { ?h schema:address ?addr }
}

# -----------------------------------------
# 4. Hospitales sin Código CCN
# -----------------------------------------
SELECT ?h
WHERE {
  ?h rdf:type schema:Hospital .
  FILTER NOT EXISTS { ?h hosp:ccnCode ?ccn }
}

# -----------------------------------------
# 5. numberOfBeds mal tipado
# -----------------------------------------
SELECT ?h ?beds
WHERE {
  ?h rdf:type schema:Hospital ;
     hosp:numberOfBeds ?beds .
  FILTER (datatype(?beds) != xsd:integer)
}

# -----------------------------------------
# 6. teachingAccreditation mal tipado
# -----------------------------------------
SELECT ?h ?acc
WHERE {
  ?h rdf:type schema:Hospital ;
     hosp:teachingAccreditation ?acc .
  FILTER (datatype(?acc) != xsd:boolean)
}

# -----------------------------------------
# 7. Direcciones sin código postal
# -----------------------------------------
SELECT ?addr
WHERE {
  ?addr rdf:type schema:PostalAddress .
  FILTER NOT EXISTS { ?addr schema:postalCode ?cp }
}

# -----------------------------------------
# 8. Direcciones incompletas
# -----------------------------------------
SELECT ?addr
WHERE {
  ?addr rdf:type schema:PostalAddress .
  {
    FILTER NOT EXISTS { ?addr schema:addressLocality ?m }
  }
  UNION
  {
    FILTER NOT EXISTS { ?addr hosp:addressProvince ?p }
  }
  UNION
  {
    FILTER NOT EXISTS { ?addr schema:addressRegion ?r }
  }
  UNION
  {
    FILTER NOT EXISTS { ?addr schema:addressCountry ?c }
  }
}

# -----------------------------------------
# 9. Recursos territoriales sin label
# -----------------------------------------
SELECT ?recurso ?tipo
WHERE {
  ?recurso rdf:type ?tipo .
  VALUES ?tipo { hosp:Municipality hosp:Province hosp:AutonomousCommunity }
  FILTER NOT EXISTS { ?recurso rdfs:label ?label }
}

# -----------------------------------------
# 10. Jerarquía territorial incompleta
# -----------------------------------------
SELECT ?recurso ?tipo
WHERE {
  {
    ?recurso rdf:type hosp:Municipality .
    BIND(hosp:Municipality AS ?tipo)
    FILTER NOT EXISTS { ?recurso hosp:containedInProvince ?prov }
  }
  UNION
  {
    ?recurso rdf:type hosp:Province .
    BIND(hosp:Province AS ?tipo)
    FILTER NOT EXISTS { ?recurso hosp:containedInRegion ?reg }
  }
  UNION
  {
    ?recurso rdf:type hosp:AutonomousCommunity .
    BIND(hosp:AutonomousCommunity AS ?tipo)
    FILTER NOT EXISTS { ?recurso hosp:containedInCountry ?country }
  }
}

# -----------------------------------------
# 11. ConcertAgreement sin tipo
# -----------------------------------------
SELECT ?c
WHERE {
  ?h hosp:hasConcertAgreement ?c .
  FILTER NOT EXISTS { ?c rdf:type hosp:ConcertAgreement }
}

# -----------------------------------------
# 12. ConcertAgreement sin label
# -----------------------------------------
SELECT ?c
WHERE {
  ?c rdf:type hosp:ConcertAgreement .
  FILTER NOT EXISTS { ?c rdfs:label ?label }
}

# -----------------------------------------
# 13. Duplicados de CCN
# -----------------------------------------
SELECT ?ccn (COUNT(?h) AS ?num)
WHERE {
  ?h rdf:type schema:Hospital ;
     hosp:ccnCode ?ccn .
}
GROUP BY ?ccn
HAVING (COUNT(?h) > 1)