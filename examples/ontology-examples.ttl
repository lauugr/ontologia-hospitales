             rdfs:label "Place" .


###  https://schema.org/PostalAddress
schema:PostalAddress rdf:type owl:Class ;
                     rdfs:label "Postal Address" .


###  https://w3id.org/def/salud/hospital#AutonomousCommunity
hosp:AutonomousCommunity rdf:type owl:Class ;
                         rdfs:subClassOf schema:AdministrativeArea ;
                         rdfs:label "Autonomous Community" .


###  https://w3id.org/def/salud/hospital#ConcertAgreement
hosp:ConcertAgreement rdf:type owl:Class ;
                      rdfs:label "Concert Agreement" .


###  https://w3id.org/def/salud/hospital#FunctionalDependency
hosp:FunctionalDependency rdf:type owl:Class ;
