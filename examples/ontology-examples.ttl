#################################################################
#    Classes
#################################################################

###  https://schema.org/AdministrativeArea
schema:AdministrativeArea rdf:type owl:Class ;
                          rdfs:label "Administrative Area" .


###  https://schema.org/CivicStructure
schema:CivicStructure rdf:type owl:Class ;
                      rdfs:subClassOf schema:Place ;
                      rdfs:label "Civic Structure" .


###  https://schema.org/Country
schema:Country rdf:type owl:Class ;
               rdfs:label "Country" .


###  https://schema.org/Hospital
schema:Hospital rdf:type owl:Class ;
                rdfs:subClassOf schema:CivicStructure ,
