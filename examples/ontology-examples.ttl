#################################################################
#    Object Properties
#################################################################

###  https://schema.org/address
schema:address rdf:type owl:ObjectProperty ;
               rdfs:domain schema:Hospital ;
               rdfs:range schema:PostalAddress ;
               rdfs:label "address" .


###  https://schema.org/addressCountry
schema:addressCountry rdf:type owl:ObjectProperty ;
                      rdfs:domain schema:PostalAddress ;
                      rdfs:range schema:Country ;
                      rdfs:label "address country" .


###  https://schema.org/addressLocality
schema:addressLocality rdf:type owl:ObjectProperty ;
                       rdfs:domain schema:PostalAddress ;
                       rdfs:range hosp:Municipality ;
                       rdfs:label "address locality" .


###  https://schema.org/addressRegion
schema:addressRegion rdf:type owl:ObjectProperty ;
                     rdfs:domain schema:PostalAddress ;
                     rdfs:range hosp:AutonomousCommunity ;
                     rdfs:label "address region" .


###  https://w3id.org/def/salud/hospital#addressProvince
hosp:addressProvince rdf:type owl:ObjectProperty ;
                     rdfs:domain schema:PostalAddress ;
                     rdfs:range hosp:Province ;
                     rdfs:label "address province" .


###  https://w3id.org/def/salud/hospital#containedInCountry
hosp:containedInCountry rdf:type owl:ObjectProperty ;
                        rdfs:domain hosp:AutonomousCommunity ;
                        rdfs:range schema:Country ;
                        rdfs:label "contained in country" .


###  https://w3id.org/def/salud/hospital#containedInProvince
hosp:containedInProvince rdf:type owl:ObjectProperty ;
                         rdfs:domain hosp:Municipality ;
                         rdfs:range hosp:Province ;
                         rdfs:label "contained in province" .


###  https://w3id.org/def/salud/hospital#containedInRegion
hosp:containedInRegion rdf:type owl:ObjectProperty ;
                       rdfs:domain hosp:Province ;
                       rdfs:range hosp:AutonomousCommunity ;
                       rdfs:label "contained in region" .


###  https://w3id.org/def/salud/hospital#hasConcertAgreement
hosp:hasConcertAgreement rdf:type owl:ObjectProperty ;
                         rdfs:domain schema:Hospital ;
                         rdfs:range hosp:ConcertAgreement ;
                         rdfs:label "has concert agreement" .


###  https://w3id.org/def/salud/hospital#hasFunctionalDependency
hosp:hasFunctionalDependency rdf:type owl:ObjectProperty ;
                             rdfs:domain schema:Hospital ;
                             rdfs:range hosp:FunctionalDependency ;
                             rdfs:label "has functional dependency" .


###  https://w3id.org/def/salud/hospital#hasHospitalType
hosp:hasHospitalType rdf:type owl:ObjectProperty ;
                     rdfs:domain schema:Hospital ;
                     rdfs:range hosp:HospitalType ;
                     rdfs:label "has hospital type" .


